   <stop offset=\"100%\" stopColor={color} stopOpacity={0.01} />\n            </linearGradient>\n          </defs>\n          <CartesianGrid vertical={false} stroke=\"rgba(255,255,255,0.06)\" />\n          <XAxis\n            dataKey=\"label\"\n            axisLine={false}\n            tickLine={false}\n            tick={{ fill: \"rgba(222,228,255,0.5)\", fontSize: 11 }}\n          />\n          <YAxis\n            axisLine={false}\n            tickLine={false}\n            tick={{ fill: \"rgba(222,228,255,0.5)\", fontSize: 11 }}\n            tickFormatter={yLabelFormatter}\n          />\n          <Tooltip content={<CustomTooltip formatter={yLabelFormatter} />} />\n          <Area\n            type=\"monotone\"\n            dataKey={dataKey}\n            stroke={color}\n            strokeWidth={2.8}\n            fill={`url(#${gradientId})`}\n            dot={{ r: 0 }}\n            activeDot={{ r: 5, fill: color, stroke: \"#dcefff\", strokeWidth: 2 }}\n            isAnimationActive={false}\n          />\n        </AreaChart>\n      </ResponsiveContainer>\n    </div>\n  );\n}\n"],"mappings":"AAAA,OACEA,IAAI,CACJC,SAAS,CACTC,aAAa,CACbC,OAAO,CACPC,mBAAmB,CACnBC,KAAK,CACLC,KAAK,KACA,UAAU,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAElB,QAAS,CAAAC,aAAaA,CAAAC,IAAA,CAAwC,IAAvC,CAAEC,MAAM,CAAEC,OAAO,CAAEC,KAAK,CAAEC,SAAU,CAAC,CAAAJ,IAAA,CAC1D,GAAI,CAACC,MAAM,EAAI,EAACC,OAAO,SAAPA,OAAO,WAAPA,OAAO,CAAEG,MAAM,EAAE,CAC/B,MAAO,KAAI,CACb,CAEA,KAAM,CAAAC,IAAI,CAAGJ,OAAO,CAAC,CAAC,CAAC,CAEvB,mBACEJ,KAAA,QAAKS,SAAS,CAAC,eAAe,CAAAC,QAAA,eAC5BZ,IAAA,QAAKW,SAAS,CAAC,qBAAqB,CAAAC,QAAA,CAAEL,KAAK,CAAM,CAAC,cAClDP,IAAA,QAAKW,SAAS,CAAC,qBAAqB,CAAAC,QAAA,CACjCJ,SAAS,CAAGA,SAAS,CAACE,IAAI,CAACG,KAAK,CAAC,CAAGH,IAAI,CAACG,KAAK,CAC5C,CAAC,EACH,CAAC,CAEV,CAEA,cAAe,SAAS,CAAAC,kBAAkBA,CAAAC,KAAA,CAKvC,IALwC,CACzCC,IAAI,CACJC,OAAO,CAAG,OAAO,CACjBC,KAAK,CAAG,SAAS,CACjBC,eACF,CAAC,CAAAJ,KAAA,CACC,KAAM,CAAAK,UAAU,CAAG,kBAAkBF,KAAK,CAACG,OAAO,CAAC,GAAG,CAAE,EAAE,CAAC,EAAE,CAE7D,mBACErB,IAAA,QA